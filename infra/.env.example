# 3D Medical CLIP — local environment template (P1).
# Copy to `infra/.env` and adjust. `infra/.env` is git-ignored (never committed).
# All services bind to 127.0.0.1 only; these are local single-user dev defaults.

# --- PostgreSQL ---
POSTGRES_USER=medclip
# Dev-only default; override for anything beyond a local loopback dev database.
POSTGRES_PASSWORD=medclip_dev_only
POSTGRES_DB=medclip
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Qdrant ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Backend (used from P1/S3) ---
BACKEND_PORT=8000
# Comma-separated allowed CORS origins for the local frontend.
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Frontend (used from P1/S3) ---
FRONTEND_PORT=5173
